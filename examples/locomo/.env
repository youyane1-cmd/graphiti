# Graph storage backend
GRAPH_BACKEND=falkordb
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_DATABASE=graphiti_memory
FALKORDB_USERNAME=
FALKORDB_PASSWORD=

# OpenAI-compatible LLM and embedding endpoint
OPENAI_API_KEY=dummy
OPENAI_BASE_URL=http://10.112.86.11:80/v1

# Chat model used for extraction, deduplication, summarization, and optional reranking
LLM_MODEL=gpt-5.4-mini
SMALL_LLM_MODEL=gpt-5.4-mini

# Embedding model and output dimension
EMBEDDING_MODEL=http://10.112.86.11:80/v1
EMBEDDING_DIM=384

# Use json_object if your provider does not reliably support json_schema response_format
STRUCTURED_OUTPUT_MODE=json_object
