# Graph storage backend: Docker FalkorDB
GRAPH_BACKEND=falkordb

FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_DATABASE=graphiti_memory
FALKORDB_USERNAME=
FALKORDB_PASSWORD=

# OpenAI-compatible LLM and embedding endpoint
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://your-base-url/v1

# Chat model used for extraction, deduplication, summarization, and optional reranking
LLM_MODEL=your-chat-model
SMALL_LLM_MODEL=your-chat-model

# Embedding model and output dimension
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_DIM=1024

# Use json_object if your provider does not reliably support json_schema response_format
STRUCTURED_OUTPUT_MODE=json_schema
